# Dashboard Environment Configuration
# Copy this file to .env and modify values as needed

# Database Configuration
DATABASE_HOST=your_databricks_workspace_url
DATABASE_TOKEN=your_databricks_token
DATABASE_WAREHOUSE_ID=your_sql_warehouse_id

# Dashboard Settings
DASHBOARD_TITLE="Sales Analytics Dashboard"
REFRESH_INTERVAL_SECONDS=300
CACHE_DURATION_SECONDS=1800
MAX_ROWS_PER_QUERY=10000

# Export Settings
EXPORT_FORMATS="pdf,excel,csv"
EXPORT_PATH="/dbfs/FileStore/exports/"

# Visualization Settings
CHART_THEME="plotly_white"
COLOR_PALETTE="blues"
FIGURE_WIDTH=800
FIGURE_HEIGHT=600

# Security Settings
ENABLE_ROW_LEVEL_SECURITY=false
AUDIT_LOGGING=true

# Performance Settings
ENABLE_QUERY_CACHING=true
ENABLE_RESULT_CACHING=true
PARALLEL_PROCESSING=true